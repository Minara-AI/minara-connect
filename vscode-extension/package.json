{
  "name": "cc-connect-vscode",
  "displayName": "cc-connect",
  "description": "Peer-to-peer chat substrate for shared Claude Code context",
  "version": "0.1.0",
  "publisher": "minara",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Minara-AI/cc-connect.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:cc-connect.rooms"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cc-connect",
          "title": "cc-connect",
          "icon": "media/cc-connect-activity.svg"
        }
      ],
      "panel": [
        {
          "id": "cc-connect-panel",
          "title": "cc-connect Room",
          "icon": "media/cc-connect-activity.svg"
        }
      ]
    },
    "views": {
      "cc-connect": [
        {
          "id": "cc-connect.rooms",
          "name": "Rooms",
          "icon": "media/cc-connect-activity.svg",
          "contextualTitle": "cc-connect"
        }
      ],
      "cc-connect-panel": [
        {
          "id": "cc-connect.room",
          "name": "Room",
          "type": "webview",
          "contextualTitle": "cc-connect"
        }
      ]
    },
    "commands": [
      {
        "command": "cc-connect.hello",
        "title": "Hello",
        "category": "cc-connect"
      },
      {
        "command": "cc-connect.startRoom",
        "title": "Start Room",
        "category": "cc-connect",
        "icon": "$(add)"
      },
      {
        "command": "cc-connect.joinRoom",
        "title": "Join Room…",
        "category": "cc-connect",
        "icon": "$(cloud-download)"
      },
      {
        "command": "cc-connect.openRoom",
        "title": "Open Room (existing)",
        "category": "cc-connect"
      },
      {
        "command": "cc-connect.showTicket",
        "title": "Show Ticket…",
        "category": "cc-connect",
        "icon": "$(clippy)"
      },
      {
        "command": "cc-connect.stopRoom",
        "title": "Stop Room…",
        "category": "cc-connect",
        "icon": "$(stop)"
      },
      {
        "command": "cc-connect.refreshRooms",
        "title": "Refresh",
        "category": "cc-connect",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cc-connect.startRoom",
          "when": "view == cc-connect.rooms",
          "group": "navigation@1"
        },
        {
          "command": "cc-connect.joinRoom",
          "when": "view == cc-connect.rooms",
          "group": "navigation@2"
        },
        {
          "command": "cc-connect.refreshRooms",
          "when": "view == cc-connect.rooms",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "cc-connect.showTicket",
          "when": "view == cc-connect.rooms && viewItem == room.alive",
          "group": "inline@1"
        },
        {
          "command": "cc-connect.stopRoom",
          "when": "view == cc-connect.rooms && viewItem == room.alive",
          "group": "inline@2"
        },
        {
          "command": "cc-connect.openRoom",
          "when": "view == cc-connect.rooms",
          "group": "1_open"
        },
        {
          "command": "cc-connect.showTicket",
          "when": "view == cc-connect.rooms && viewItem == room.alive",
          "group": "2_clipboard"
        },
        {
          "command": "cc-connect.stopRoom",
          "when": "view == cc-connect.rooms && viewItem == room.alive",
          "group": "3_destructive"
        }
      ]
    }
  },
  "scripts": {
    "compile": "bun run compile:host && bun run compile:webview",
    "compile:host": "tsc -p .",
    "compile:webview": "bun build ./webview/main.tsx --outdir ./dist/webview --format esm --target browser --jsx-factory React.createElement --jsx-fragment React.Fragment --sourcemap=external",
    "watch": "tsc -p . --watch",
    "vscode:prepublish": "bun run compile",
    "probe:sdk": "bun run scripts/probe-sdk.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.4.0"
  }
}
