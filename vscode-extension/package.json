{
  "name": "cc-connect-vscode",
  "displayName": "cc-connect",
  "description": "Peer-to-peer chat substrate for shared Claude Code context",
  "version": "0.1.0",
  "publisher": "minara",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Minara-AI/cc-connect.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:cc-connect.hello",
    "onCommand:cc-connect.openRoom",
    "onCommand:cc-connect.startRoom",
    "onCommand:cc-connect.joinRoom"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cc-connect.hello",
        "title": "Hello",
        "category": "cc-connect"
      },
      {
        "command": "cc-connect.startRoom",
        "title": "Start Room",
        "category": "cc-connect"
      },
      {
        "command": "cc-connect.joinRoom",
        "title": "Join Room…",
        "category": "cc-connect"
      },
      {
        "command": "cc-connect.openRoom",
        "title": "Open Room (existing)",
        "category": "cc-connect"
      }
    ]
  },
  "scripts": {
    "compile": "bun run compile:host && bun run compile:webview",
    "compile:host": "tsc -p .",
    "compile:webview": "bun build ./webview/main.tsx --outdir ./dist/webview --format esm --target browser --jsx-factory React.createElement --jsx-fragment React.Fragment --sourcemap=external",
    "watch": "tsc -p . --watch",
    "vscode:prepublish": "bun run compile",
    "probe:sdk": "bun run scripts/probe-sdk.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.4.0"
  }
}
