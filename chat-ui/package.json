{
  "name": "cc-chat-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "cc-connect chat panel (Bun + React + Ink). Talks to chat-daemon via ~/.cc-connect/rooms/<topic>/chat.sock and tails log.jsonl. Run as one pane of a zellij/tmux layout next to claude.",
  "main": "src/main.tsx",
  "scripts": {
    "build": "bun build src/main.tsx --compile --outfile=../target/release/cc-chat-ui",
    "dev": "bun run src/main.tsx",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "typescript": "^5.7.2"
  }
}
